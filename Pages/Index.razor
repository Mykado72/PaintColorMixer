    {
        hslHue = int.Parse(e.Value!.ToString()!);
        StateHasChanged();
    }

    private void OnSatSliderChange(ChangeEventArgs e)
    {
        hslSat = int.Parse(e.Value!.ToString()!);
        StateHasChanged();
    }

    private void OnLitSliderChange(ChangeEventArgs e)
    {
        hslLit = int.Parse(e.Value!.ToString()!);
        StateHasChanged();
    }

    // ─── Pipette : chargement image ─────────────────────────────────────────────
    private string? _pendingPipetteDataUrl = null;

    private async Task OnImageUpload(InputFileChangeEventArgs e)
    {
        pipetteColor = null;
        var file = e.File;
        if (file == null) return;

        using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        using var ms     = new System.IO.MemoryStream();
        await stream.CopyToAsync(ms);
        var base64   = Convert.ToBase64String(ms.ToArray());
        var mimeType = string.IsNullOrEmpty(file.ContentType) ? "image/jpeg" : file.ContentType;
        var dataUrl  = $"data:{mimeType};base64,{base64}";

        // 1. Stocker le dataUrl et afficher le canvas d'abord
        pipetteImageData       = dataUrl;
        _pendingPipetteDataUrl = dataUrl;
        StateHasChanged(); // re-rendu : le canvas apparaît dans le DOM
    }

    // 2. Une fois le canvas dans le DOM, dessiner l'image
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingPipetteDataUrl != null)
        {
            var dataUrl = _pendingPipetteDataUrl;
            _pendingPipetteDataUrl = null;
            var dotNetRef = DotNetObjectReference.Create(this);
            await Task.Delay(30); // s'assurer que le canvas est rendu
            await JS.InvokeVoidAsync("chromaMix.loadPipetteFromDataUrl", dataUrl, dotNetRef);
        }
    }

    [JSInvokable]
    public async Task OnPipetteImageReady(string dataUrl)
    {
        // Image déjà affichée, juste confirmer
        StateHasChanged();
        await Task.CompletedTask;
    }

    private async Task OnPipetteMouseMove(MouseEventArgs e)
    {
        zoomX = e.OffsetX - 80;
        zoomY = e.OffsetY - 80;
        var rgb = await JS.InvokeAsync<int[]>("chromaMix.pipettePreview", e.OffsetX, e.OffsetY);
        if (rgb != null && rgb.Length == 3)
            pipetteColor = new ColorInfo(rgb[0], rgb[1], rgb[2]);
        StateHasChanged();
    }

    private async Task OnPipetteClick(MouseEventArgs e)
    {
        var rgb = await JS.InvokeAsync<int[]>("chromaMix.pipettePreview", e.OffsetX, e.OffsetY);
        if (rgb == null || rgb.Length < 3) return;
        pipetteColor = new ColorInfo(rgb[0], rgb[1], rgb[2]);
        StateHasChanged();
    }

    private async Task OnPipetteTouchMove(TouchEventArgs e)
    {
        if (e.Touches.Length == 0) return;
        var t   = e.Touches[0];
        var pos = await JS.InvokeAsync<double[]>("chromaMix.getCanvasOffset", "pipetteCanvas", t.ClientX, t.ClientY);
        if (pos == null) return;
        zoomX = pos[0] - 80;
        zoomY = pos[1] - 80;
        var rgb = await JS.InvokeAsync<int[]>("chromaMix.pipettePreview", pos[0], pos[1]);
        if (rgb != null && rgb.Length == 3)
            pipetteColor = new ColorInfo(rgb[0], rgb[1], rgb[2]);
        StateHasChanged();
    }

    private void OnPipetteTouchEnd(TouchEventArgs e) { zoomX = -200; zoomY = -200; StateHasChanged(); }

    private async Task ConfirmPipetteColor()
    {
        if (pipetteColor == null) return;
        selectedColor = pipetteColor;
        selectedHue   = selectedColor.H;
        saturation    = selectedColor.S;
        lightness     = selectedColor.L;
        ComputeMix();
        StateHasChanged();
        await JS.InvokeVoidAsync("chromaMix.scrollToResults");
    }

    private async Task ConfirmHslColor()
    {
        selectedHue   = hslHue;
        saturation    = hslSat;
        lightness     = hslLit;
        selectedColor = ColorFromHSL(hslHue, hslSat, hslLit);
        ComputeMix();
        StateHasChanged();
        await JS.InvokeVoidAsync("chromaMix.scrollToResults");
    }

    // ─── Mélange ─────────────────────────────────────────────────────────────
    private void ComputeMix()
    {
        if (selectedColor == null || currentBrand == null) { mixResult = null; return; }
        mixResult = MixingEngine.Compute(selectedColor, currentBrand.Colors, paintMode!.Value, waterRatio);
    }

    // ─── Utilitaires ─────────────────────────────────────────────────────────
    private string DeltaBadgeClass(double d) =>
        d < 2 ? "excellent" : d < 5 ? "good" : d < 10 ? "fair" : "poor";

    private static ColorInfo ColorFromHSL(double h360, int s100, int l100)
    {
        var (r, g, b) = HslToRgb(h360 / 360.0, s100 / 100.0, l100 / 100.0);
        return new ColorInfo(r, g, b);
    }

    private static (int r, int g, int b) HslToRgb(double h, double s, double l)
    {
        if (s == 0) { int v = (int)Math.Round(l * 255); return (v, v, v); }
        double q = l < 0.5 ? l * (1 + s) : l + s - l * s;
        double p = 2 * l - q;
        return (Hue(p, q, h + 1.0/3), Hue(p, q, h), Hue(p, q, h - 1.0/3));

        static int Hue(double p, double q, double t)
        {
            if (t < 0) t += 1; if (t > 1) t -= 1;
            double v = t < 1.0/6 ? p + (q-p)*6*t
                     : t < 0.5   ? q
                     : t < 2.0/3 ? p + (q-p)*(2.0/3-t)*6
                     : p;
            return (int)Math.Round(v * 255);
        }
    }
