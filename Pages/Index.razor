@page "/"
@using ColorMixer.Models
@inject IJSRuntime JS

<PageTitle>ChromaMix — Calculateur de mélanges</PageTitle>

<div class="app-shell">

@if (paintMode == null)
{
    <!-- ══ ÉCRAN D'ACCUEIL ══════════════════════════════════════════════════ -->
    <div class="welcome-screen">
        <div class="welcome-inner">
            <div class="welcome-logo">
                <span class="logo-icon">◈</span>
                <span class="logo-text">ChromaMix</span>
            </div>
            <p class="welcome-sub">Calculateur de formules de mélange de peinture</p>
            <p class="welcome-question">Quel type de peinture utilisez-vous ?</p>

            <div class="mode-cards">
                <button class="mode-card opaque-card" @onclick='() => SelectMode(PaintMode.Opaque)'>
                    <div class="mode-icon">🎨</div>
                    <div class="mode-title">Peinture opaque</div>
                    <div class="mode-desc">Acrylique · Huile · Gouache · Maquette</div>
                    <div class="mode-brands">Vallejo · Citadel · Liquitex</div>
                </button>
                <button class="mode-card watercolor-card" @onclick='() => SelectMode(PaintMode.Watercolor)'>
                    <div class="mode-icon">💧</div>
                    <div class="mode-title">Aquarelle</div>
                    <div class="mode-desc">Transparente · Sur papier · Dilution à l'eau</div>
                    <div class="mode-brands">Mijello · Daler-Rowney</div>
                </button>
            </div>
        </div>
        <p class="welcome-dedication">Réalisé par Mickael LEHAY pour Laeticia 🎨</p>
    </div>
}
else
{
    <!-- ══ INTERFACE PRINCIPALE ═════════════════════════════════════════════ -->
    <header class="app-header">
        <div class="logo">
            <span class="logo-icon">◈</span>
            <span class="logo-text">ChromaMix</span>
        </div>
        <div class="mode-badge @(paintMode == PaintMode.Watercolor ? "wc" : "op")">
            @(paintMode == PaintMode.Watercolor ? "💧 Aquarelle" : "🎨 Opaque")
        </div>
        <button class="change-mode-btn" @onclick="ResetMode">Changer de mode</button>
    </header>

    <main class="main-layout">

        <!-- ── GAUCHE : Roue ────────────────────────────────────────────────── -->
        <section class="panel wheel-panel">
            <h2 class="panel-title">Sélection de couleur</h2>

            <!-- Onglets Roue / Sliders -->
            <div class="picker-tabs">
                <button class="picker-tab @(pickerTab == 0 ? "active" : "")" @onclick='() => SwitchTab(0)'>🎡 Roue</button>
                <button class="picker-tab @(pickerTab == 1 ? "active" : "")" @onclick='() => SwitchTab(1)'>🎚 Sliders</button>
                <button class="picker-tab @(pickerTab == 2 ? "active" : "")" @onclick='() => SwitchTab(2)'>🔬 Pipette</button>
            </div>

            <!-- TAB 0 : Roue chromatique -->
            @if (pickerTab == 0)
            {
                <div class="wheel-wrapper">
                    <canvas id="colorWheel" width="340" height="340"
                            @onmousemove="OnWheelMouseMove"
                            @onclick="OnWheelClick"
                            @onmouseleave="OnWheelMouseLeave"
                            @ontouchstart:preventDefault="true"
                            @ontouchstart="OnWheelTouchStart"
                            @ontouchmove:preventDefault="true"
                            @ontouchmove="OnWheelTouchMove"
                            @ontouchend="OnWheelTouchEnd"
                            style="cursor:crosshair; border-radius:50%; touch-action:none;" />
                    <!-- Canvas loupe — toujours présent, déplacé via JS -->
                    <canvas id="wheelZoomCanvas" class="wheel-zoom-canvas" style="display:none;"></canvas>
                </div>
                <div class="sliders-group">
                    <div class="slider-row">
                        <label>Saturation</label>
                        <input type="range" min="0" max="100" step="1" value="@saturation"
                               @oninput="OnSaturationChange" class="styled-slider saturation-slider" />
                        <span class="slider-val">@saturation%</span>
                    </div>
                    <div class="slider-row">
                        <label>Luminosité</label>
                        <input type="range" min="5" max="95" step="1" value="@lightness"
                               @oninput="OnLightnessChange" class="styled-slider lightness-slider" />
                        <span class="slider-val">@lightness%</span>
                    </div>
                </div>
            }

            <!-- TAB 1 : Sliders H/S/L grands (mobile-friendly) -->
            @if (pickerTab == 1)
            {
                <div class="hsl-picker">
                    <!-- Prévisualisation live -->
                    <div class="hsl-preview" style="background:@(selectedColor?.Hex ?? HslPreviewHex);">
                        <span class="hsl-preview-hex">@(selectedColor?.Hex ?? HslPreviewHex)</span>
                    </div>

                    <div class="hsl-sliders">
                        <div class="hsl-row">
                            <span class="hsl-label">T</span>
                            <div class="hsl-track hue-track">
                                <input type="range" min="0" max="360" step="1" value="@hslHue"
                                       @oninput="OnHueSliderChange" class="hsl-input hue-input" />
                            </div>
                            <span class="hsl-val">@hslHue°</span>
                        </div>
                        <div class="hsl-row">
                            <span class="hsl-label">S</span>
                            <div class="hsl-track" style="background: linear-gradient(to right, hsl(@hslHue,0%,50%), hsl(@hslHue,100%,50%));">
                                <input type="range" min="0" max="100" step="1" value="@hslSat"
                                       @oninput="OnSatSliderChange" class="hsl-input" />
                            </div>
                            <span class="hsl-val">@hslSat%</span>
                        </div>
                        <div class="hsl-row">
                            <span class="hsl-label">L</span>
                            <div class="hsl-track" style="background: linear-gradient(to right, #000, hsl(@hslHue,@(hslSat)%,50%), #fff);">
                                <input type="range" min="0" max="100" step="1" value="@hslLit"
                                       @oninput="OnLitSliderChange" class="hsl-input" />
                            </div>
                            <span class="hsl-val">@hslLit%</span>
                        </div>
                    </div>

                    <button class="hsl-confirm" @onclick="ConfirmHslColor">
                        Sélectionner cette couleur
                    </button>
                </div>
            }

            <!-- TAB 2 : Pipette avec zoom -->
            @if (pickerTab == 2)
            {
                <div class="pipette-panel">
                    <p class="pipette-hint">Importez une image puis pointez la couleur à extraire</p>

                    <label class="pipette-upload">
                        <InputFile id="pipetteFileInput" accept="image/*" OnChange="OnImageUpload" style="display:none;" />
                        <span>📁 Choisir une image</span>
                    </label>

                    @if (pipetteImageData != null)
                    {
                        <div class="pipette-canvas-wrap" id="pipette-wrap">
                            <canvas id="pipetteCanvas"
                                    @onmousemove="OnPipetteMouseMove"
                                    @onclick="OnPipetteClick"
                                    @ontouchmove:preventDefault="true"
                                    @ontouchmove="OnPipetteTouchMove"
                                    @ontouchend="OnPipetteTouchEnd"
                                    style="cursor:none; touch-action:none;" />
                            <!-- Loupe -->
                            <canvas id="zoomCanvas" class="zoom-lens" style="left:@(zoomX)px; top:@(zoomY)px;" />
                            <!-- Croix centrale de la loupe -->
                            <div class="zoom-crosshair" style="left:@(zoomX)px; top:@(zoomY)px;"></div>
                        </div>

                        @if (pipetteColor != null)
                        {
                            <div class="pipette-result">
                                <div class="pipette-swatch" style="background:@pipetteColor.Hex;"></div>
                                <div class="pipette-info">
                                    <span class="pipette-hex">@pipetteColor.Hex</span>
                                    <span class="pipette-rgb">RVB(@pipetteColor.R, @pipetteColor.G, @pipetteColor.B)</span>
                                </div>
                                <button class="pipette-confirm" @onclick="ConfirmPipetteColor">✓ Utiliser</button>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="pipette-placeholder">
                            <span>🖼️</span>
                            <p>Chargez une photo, un nuancier ou toute image pour en extraire une couleur avec zoom</p>
                        </div>
                    }
                </div>
            }

            <!-- Dilution aquarelle (toujours visible) -->
            @if (paintMode == PaintMode.Watercolor)
            {
                <div class="sliders-group" style="padding-top:0; border-top: 1px solid var(--border); margin-top: 4px;">
                    <div class="slider-row">
                        <label>Dilution</label>
                        <input type="range" min="0" max="80" step="1" value="@waterRatio"
                               @oninput="OnWaterChange" class="styled-slider water-slider" />
                        <span class="slider-val">@waterRatio%</span>
                    </div>
                </div>
            }

            @if (selectedColor != null)
            {
                <div class="selected-color-card">
                    <div class="color-swatch large" style="background:@selectedColor.Hex;"></div>
                    <div class="color-info">
                        <div class="color-hex">@selectedColor.Hex</div>
                        <div class="color-hsl">T : @selectedColor.H°  S : @selectedColor.S%  L : @selectedColor.L%</div>
                        <div class="color-rgb">RVB(@selectedColor.R, @selectedColor.G, @selectedColor.B)</div>
                    </div>
                </div>
            }
            else
            {
                <div class="placeholder-card">
                    <span>Cliquez sur la roue pour sélectionner une couleur</span>
                </div>
            }
        </section>

        <!-- ── CENTRE : Marque ─────────────────────────────────────────────── -->
        <section class="panel brand-panel">
            <h2 class="panel-title">Marque</h2>
            <div class="brand-tabs">
                @foreach (var brand in PaintDatabase.GetBrands(paintMode.Value))
                {
                    <button class="brand-tab @(selectedBrand == brand.Name ? "active" : "")"
                            @onclick="() => SelectBrand(brand.Name)">
                        @brand.Name
                    </button>
                }
            </div>

            @if (currentBrand != null)
            {
                <div class="palette-grid">
                    @foreach (var paint in currentBrand.Colors)
                    {
                        <div class="palette-chip @(IsColorInMix(paint) ? "in-mix" : "") @(IsPaletteSelected(paint) ? "selected-chip" : "")"
                             title="@GetChipTitle(paint)"
                             style="background:@paint.Hex;"
                             @onclick="() => SelectPaletteColor(paint)">
                            @if (paintMode == PaintMode.Watercolor)
                            {
                                <span class="chip-icons">
                                    @if (paint.IsTransparent) { <span title="Transparent">◎</span> }
                                    @if (paint.IsGranulating) { <span title="Granulant">⋮</span>  }
                                    @if (paint.IsStaining)    { <span title="Tachant">✦</span>    }
                                </span>
                            }
                        </div>
                    }
                </div>
                <p class="brand-note">@currentBrand.Colors.Count couleurs disponibles</p>
                @if (paintMode == PaintMode.Watercolor)
                {
                    <div class="wc-legend">
                        <span>◎ Transparent</span>
                        <span>⋮ Granulant</span>
                        <span>✦ Tachant</span>
                    </div>
                }
            }
        </section>

        <!-- ── DROITE : Résultats ───────────────────────────────────────────── -->
        <section class="panel results-panel" id="results-panel">
            <h2 class="panel-title">Formules de mélange</h2>

            @if (selectedColor == null)
            {
                <div class="empty-state">
                    <div class="empty-icon">🎨</div>
                    <p>Sélectionnez une couleur sur la roue<br/>pour obtenir les formules de mélange</p>
                </div>
            }
            else if (mixResult == null)
            {
                <div class="empty-state">
                    <div class="empty-icon">⚙️</div>
                    <p>Calcul des formules en cours…</p>
                </div>
            }
            else
            {
                @if (paintMode == PaintMode.Watercolor)
                {
                    <div class="wc-info-bar">
                        <span class="wc-info-icon">💧</span>
                        <span>Dilution : <strong>@waterRatio%</strong> eau — les couleurs sèchent plus claires</span>
                    </div>
                }

                <!-- Mélange 2 couleurs -->
                <div class="formula-card">
                    <div class="formula-header">
                        <span class="badge two">2 Couleurs</span>
                        <span class="delta-badge @DeltaBadgeClass(mixResult.Mix2.DeltaE)">
                            ΔE = @mixResult.Mix2.DeltaE.ToString("0.0")
                        </span>
                    </div>
                    @foreach (var comp in mixResult.Mix2.Components)
                    {
                        <div class="mix-component">
                            <div class="comp-swatch" style="background:@comp.Paint.Hex;"></div>
                            <div class="comp-details">
                                <div class="comp-name-row">
                                    <span class="comp-name">@comp.Paint.Name</span>
                                    <span class="comp-pct">@comp.Ratio.ToString("0")%</span>
                                </div>
                                @if (paintMode == PaintMode.Watercolor && comp.Paint.PigmentCode != "")
                                {
                                    <div class="comp-pigment">@comp.Paint.PigmentCode</div>
                                }
                            </div>
                            <div class="comp-bar-wrap">
                                <div class="comp-bar" style="@($"width:{comp.Ratio:0}%; background:{comp.Paint.Hex};")"></div>
                            </div>
                        </div>
                    }
                    <div class="result-compare">
                        <div class="compare-duo">
                            <div class="compare-swatch" style="background:@selectedColor.Hex;"></div>
                            <div class="compare-swatch" style="background:@mixResult.Mix2.ResultHex;"></div>
                        </div>
                        <div class="compare-labels">
                            <span>Cible</span>
                            <span>@(paintMode == PaintMode.Watercolor ? "Mouillé" : "Résultat")</span>
                        </div>
                        @if (paintMode == PaintMode.Watercolor)
                        {
                            <div class="compare-duo">
                                <div class="compare-swatch" style="background:@selectedColor.Hex;"></div>
                                <div class="compare-swatch" style="background:@mixResult.Mix2.DriedHex;"></div>
                            </div>
                            <div class="compare-labels">
                                <span>Cible</span>
                                <span>Sec</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Mélange 3 couleurs -->
                <div class="formula-card">
                    <div class="formula-header">
                        <span class="badge three">3 Couleurs</span>
                        <span class="delta-badge @DeltaBadgeClass(mixResult.Mix3.DeltaE)">
                            ΔE = @mixResult.Mix3.DeltaE.ToString("0.0")
                        </span>
                    </div>
                    @foreach (var comp in mixResult.Mix3.Components)
                    {
                        <div class="mix-component">
                            <div class="comp-swatch" style="background:@comp.Paint.Hex;"></div>
                            <div class="comp-details">
                                <div class="comp-name-row">
                                    <span class="comp-name">@comp.Paint.Name</span>
                                    <span class="comp-pct">@comp.Ratio.ToString("0")%</span>
                                </div>
                                @if (paintMode == PaintMode.Watercolor && comp.Paint.PigmentCode != "")
                                {
                                    <div class="comp-pigment">@comp.Paint.PigmentCode</div>
                                }
                            </div>
                            <div class="comp-bar-wrap">
                                <div class="comp-bar" style="@($"width:{comp.Ratio:0}%; background:{comp.Paint.Hex};")"></div>
                            </div>
                        </div>
                    }
                    <div class="result-compare">
                        <div class="compare-duo">
                            <div class="compare-swatch" style="background:@selectedColor.Hex;"></div>
                            <div class="compare-swatch" style="background:@mixResult.Mix3.ResultHex;"></div>
                        </div>
                        <div class="compare-labels">
                            <span>Cible</span>
                            <span>@(paintMode == PaintMode.Watercolor ? "Mouillé" : "Résultat")</span>
                        </div>
                        @if (paintMode == PaintMode.Watercolor)
                        {
                            <div class="compare-duo">
                                <div class="compare-swatch" style="background:@selectedColor.Hex;"></div>
                                <div class="compare-swatch" style="background:@mixResult.Mix3.DriedHex;"></div>
                            </div>
                            <div class="compare-labels">
                                <span>Cible</span>
                                <span>Sec</span>
                            </div>
                        }
                    </div>
                </div>

                <p class="delta-legend">ΔE : &lt;2 Excellent · &lt;5 Bon · &lt;10 Acceptable · >10 Élevé</p>
            }
        </section>

    </main>
}

</div>

@code {

    // ─── Classe retour JS ───────────────────────────────────────────────────────
    private class WheelColor
    {
        public double Hue { get; set; }
        public int    Lum { get; set; }
    }

    // ─── Mode ────────────────────────────────────────────────────────────────
    private PaintMode? paintMode;

    private async Task SelectMode(PaintMode mode)
    {
        paintMode     = mode;
        selectedBrand = PaintDatabase.GetBrands(mode).First().Name;
        currentBrand  = PaintDatabase.GetBrands(mode).First();
        selectedColor = null;
        mixResult     = null;
        // Valeurs par défaut selon le mode
        saturation = mode == PaintMode.Watercolor ? 75 : 80;
        lightness  = mode == PaintMode.Watercolor ? 75 : 50;
        StateHasChanged();
        await Task.Delay(50);
        await RedrawWheel();
    }

    private void ResetMode()
    {
        paintMode     = null;
        selectedColor = null;
        mixResult     = null;
        StateHasChanged();
    }

    // ─── État ────────────────────────────────────────────────────────────────
    private ColorInfo? selectedColor;
    private MixResult?  mixResult;
    private string      selectedBrand = "";
    private PaintBrand? currentBrand;
    private double      selectedHue   = 0;

    private int saturation = 100;
    private int lightness  = 50;
    private int waterRatio = 40;

    private bool       isHovering;
    private double     hoverX, hoverY;
    private ColorInfo? hoverColor;

    // ─── Onglet sélecteur ────────────────────────────────────────────────────
    private int pickerTab = 0; // 0=roue, 1=sliders HSL

    // Sliders HSL indépendants (onglet 1)
    private int hslHue = 180;
    private int hslSat = 80;
    private int hslLit = 50;
    private string HslPreviewHex => ColorFromHSL(hslHue, hslSat, hslLit).Hex;

    // ─── Pipette ─────────────────────────────────────────────────────────────
    private string?    pipetteImageData = null;
    private ColorInfo? pipetteColor     = null;
    private double     zoomX            = -200;
    private double     zoomY            = -200;

    // ─── Roue : dessin ───────────────────────────────────────────────────────
    private async Task RedrawWheel()
    {
        try
        {
            await JS.InvokeVoidAsync("chromaMix.drawWheel", "colorWheel", saturation, lightness);
        }
        catch { /* canvas pas encore dans le DOM */ }
    }

    // ─── Marque ──────────────────────────────────────────────────────────────
    private void SelectBrand(string name)
    {
        selectedBrand = name;
        currentBrand  = PaintDatabase.GetBrands(paintMode!.Value).FirstOrDefault(b => b.Name == name);
        if (selectedColor != null) ComputeMix();
        StateHasChanged();
    }

    private void SelectPaletteColor(PaintColor paint)
    {
        var ci = paint.ToColorInfo();
        selectedColor = ci;
        selectedHue   = ci.H;
        saturation    = ci.S;
        lightness     = ci.L;
        ComputeMix();
        StateHasChanged();
        // Pas de scroll ici car on est sur desktop généralement,
        // mais on le déclenche quand même pour mobile
        _ = JS.InvokeVoidAsync("chromaMix.scrollToResults");
    }

    private bool IsPaletteSelected(PaintColor p) =>
        selectedColor != null && p.Hex.ToUpper() == selectedColor.Hex.ToUpper();

    private string GetChipTitle(PaintColor p)
    {
        if (paintMode == PaintMode.Watercolor && p.PigmentCode != "")
            return $"{p.Name} ({p.PigmentCode})";
        return p.Name;
    }

    private bool IsColorInMix(PaintColor p) =>
        mixResult?.Mix2.Components.Any(c => c.Paint.Name == p.Name) == true ||
        mixResult?.Mix3.Components.Any(c => c.Paint.Name == p.Name) == true;

    // ─── Roue : interactions ─────────────────────────────────────────────────
    private async Task OnWheelMouseMove(MouseEventArgs e)
    {
        isHovering = true;
        hoverX = e.OffsetX; hoverY = e.OffsetY;
        try
        {
            var c = await JS.InvokeAsync<WheelColor?>("chromaMix.getColorAt", "colorWheel", e.OffsetX, e.OffsetY);
            hoverColor = c != null ? ColorFromHSL(c.Hue, saturation, c.Lum) : null;
            await JS.InvokeVoidAsync("chromaMix.drawWheelZoom", "colorWheel", "wheelZoomCanvas", e.OffsetX, e.OffsetY);
        }
        catch { hoverColor = null; }
        StateHasChanged();
    }

    private async Task OnWheelClick(MouseEventArgs e)
    {
        try
        {
            var c = await JS.InvokeAsync<WheelColor?>("chromaMix.getColorAt", "colorWheel", e.OffsetX, e.OffsetY);
            if (c == null) return;
            selectedHue   = c.Hue;
            lightness     = c.Lum;   // luminosité réelle du pixel cliqué
            selectedColor = ColorFromHSL(c.Hue, saturation, c.Lum);
            ComputeMix();
            StateHasChanged();
            await JS.InvokeVoidAsync("chromaMix.scrollToResults");
        }
        catch { }
        StateHasChanged();
    }

    // ─── Touch roue (mobile) ─────────────────────────────────────────────────
    // Sur mobile : presser et glisser pour parcourir, relâcher pour sélectionner

    private async Task OnWheelTouchStart(TouchEventArgs e)
    {
        if (e.Touches.Length == 0) return;
        var t   = e.Touches[0];
        var pos = await JS.InvokeAsync<double[]>("chromaMix.getCanvasOffset", "colorWheel", t.ClientX, t.ClientY);
        if (pos == null) return;
        isHovering = true;
        hoverX = pos[0]; hoverY = pos[1];
        try
        {
            var c = await JS.InvokeAsync<WheelColor?>("chromaMix.getColorAt", "colorWheel", pos[0], pos[1]);
            hoverColor = c != null ? ColorFromHSL(c.Hue, saturation, c.Lum) : null;
            await JS.InvokeVoidAsync("chromaMix.drawWheelZoom", "colorWheel", "wheelZoomCanvas", pos[0], pos[1]);
        }
        catch { hoverColor = null; }
        StateHasChanged();
    }

    private async Task OnWheelTouchMove(TouchEventArgs e)
    {
        if (e.Touches.Length == 0) return;
        var t   = e.Touches[0];
        var pos = await JS.InvokeAsync<double[]>("chromaMix.getCanvasOffset", "colorWheel", t.ClientX, t.ClientY);
        if (pos == null) return;
        hoverX = pos[0]; hoverY = pos[1];
        try
        {
            var c = await JS.InvokeAsync<WheelColor?>("chromaMix.getColorAt", "colorWheel", pos[0], pos[1]);
            hoverColor = c != null ? ColorFromHSL(c.Hue, saturation, c.Lum) : null;
            await JS.InvokeVoidAsync("chromaMix.drawWheelZoom", "colorWheel", "wheelZoomCanvas", pos[0], pos[1]);
        }
        catch { hoverColor = null; }
        StateHasChanged();
    }

    private async Task OnWheelTouchEnd(TouchEventArgs e)
    {
        // Sélectionner la couleur survolée au moment du relâchement
        if (hoverColor != null)
        {
            selectedColor = hoverColor;
            selectedHue   = hoverColor.H;
            lightness     = hoverColor.L;
            ComputeMix();
        }
        isHovering = false;
        hoverColor = null;
        await JS.InvokeVoidAsync("chromaMix.hideWheelZoom", "wheelZoomCanvas");
        StateHasChanged();
        await JS.InvokeVoidAsync("chromaMix.scrollToResults");
    }

    private async Task OnWheelMouseLeave(MouseEventArgs e)
    {
        isHovering = false;
        hoverColor = null;
        await JS.InvokeVoidAsync("chromaMix.hideWheelZoom", "wheelZoomCanvas");
        StateHasChanged();
    }

    // ─── Sliders ─────────────────────────────────────────────────────────────
    private async Task OnSaturationChange(ChangeEventArgs e)
    {
        saturation = int.Parse(e.Value!.ToString()!);
        await RedrawWheel();
        RefreshSelectedColor();
    }

    private async Task OnLightnessChange(ChangeEventArgs e)
    {
        lightness = int.Parse(e.Value!.ToString()!);
        await RedrawWheel();
        RefreshSelectedColor();
    }

    private void OnWaterChange(ChangeEventArgs e)
    {
        waterRatio = int.Parse(e.Value!.ToString()!);
        if (selectedColor != null) ComputeMix();
        StateHasChanged();
    }

    private void RefreshSelectedColor()
    {
        if (selectedColor == null) return;
        selectedColor = ColorFromHSL(selectedHue, saturation, lightness);
        ComputeMix();
        StateHasChanged();
    }

    // ─── Onglet picker ───────────────────────────────────────────────────────────
    private async Task SwitchTab(int tab)
    {
        pickerTab = tab;
        StateHasChanged();
        if (tab == 0)
        {
            await Task.Delay(30);
            await RedrawWheel();
        }
    }

